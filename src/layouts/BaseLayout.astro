---
import '../styles/global.css';
import { withBase } from '../utils/withBase';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '복잡한 도구형 UI를 사용자가 실행 가능한 흐름으로 바꾸는 프론트엔드 개발자 김민찬의 포트폴리오' } = Astro.props;

const siteUrl = import.meta.env.SITE;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

const navItems = [
  { href: withBase(), label: 'Home' },
  { href: withBase('about/'), label: 'About' },
  { href: withBase('case-studies/'), label: 'Case Studies' },
  { href: withBase('contact/'), label: 'Contact' }
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="김민찬 Portfolio" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-100">
    <header class="border-b border-slate-800">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href={withBase()} class="text-sm font-semibold tracking-wide text-cyan-300">MINCHAN PORTFOLIO</a>
        <nav class="flex gap-4 text-sm text-slate-300">
          {navItems.map((item) => (
            <a href={item.href} class="transition hover:text-white">{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-5xl px-6 py-12">
      <slot />
    </main>
    <footer class="border-t border-slate-800">
      <div class="mx-auto flex max-w-5xl flex-wrap justify-between gap-3 px-6 py-6 text-sm text-slate-400">
        <p>© {new Date().getFullYear()} 김민찬</p>
        <p>복잡한 도구형 UI를 실행 가능한 제품 경험으로 바꾸는 FE Developer</p>
      </div>
    </footer>
  </body>
</html>
