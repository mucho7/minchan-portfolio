---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import { withBase } from '../utils/withBase';

const caseStudies = (await getCollection('case-studies'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  title="김민찬 | FE Developer Portfolio"
  description="복잡한 도구형 UI를 실행 가능한 제품 경험으로 바꾸는 프론트엔드 개발자 김민찬의 포트폴리오"
>
  <section class="space-y-6">
    <p class="text-sm text-cyan-300">FE Developer 김민찬</p>
    <h1 class="text-4xl font-bold leading-tight sm:text-5xl">
      복잡한 도구형 UI를
      <br />
      사용자가 실행 가능한 흐름으로 바꾸는
      <br />
      프론트엔드 개발자
    </h1>
    <p class="max-w-3xl text-lg text-slate-300">
      Agent, 시계열 데이터, 워크플로우처럼 이해하기 어려운 도메인을
      문제 정의, 의사결정, 구현, 성과 중심으로 정리했습니다.
    </p>
    <div class="flex flex-wrap gap-4 pt-2">
      <a
        href={withBase('case-studies/')}
        class="inline-block rounded-lg bg-cyan-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-cyan-500"
      >
        Case Study 보기
      </a>
      <a
        href="https://velog.io/@kimjih94/posts"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-lg border border-slate-700 px-5 py-2.5 text-sm font-medium text-slate-200 transition hover:border-cyan-400 hover:text-white"
      >
        블로그 방문하기
      </a>
    </div>
  </section>

  <section class="mt-14 space-y-5">
    <div class="flex items-end justify-between">
      <h2 class="text-2xl font-semibold">대표 Case Study</h2>
      <a href={withBase('case-studies/')} class="text-sm text-cyan-300 hover:text-cyan-200">전체 보기</a>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {caseStudies.map((study) => (
        <CaseStudyCard study={study} />
      ))}
    </div>
  </section>
</BaseLayout>
