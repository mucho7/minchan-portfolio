---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies');
  return studies.map((study) => ({
    params: { slug: study.id },
    props: { study }
  }));
}

interface Props {
  study: CollectionEntry<'case-studies'>;
}

const { study } = Astro.props;
const { Content } = await render(study);
---

<BaseLayout
  title={`${study.data.title} | Case Study`}
  description={study.data.summary}
>
  <article class="space-y-8">
    <header class="space-y-3">
      <p class="text-sm text-cyan-300">Case Study</p>
      <h1 class="text-3xl font-bold">{study.data.title}</h1>
      <p class="text-slate-300">{study.data.summary}</p>
      <div class="flex flex-wrap gap-4 text-sm text-slate-400">
        <span>{study.data.period}</span>
        <span>{study.data.role}</span>
      </div>
      <ul class="flex flex-wrap gap-2">
        {study.data.skills.map((skill) => (
          <li class="rounded-md bg-slate-800 px-2 py-1 text-xs text-slate-200">{skill}</li>
        ))}
      </ul>
      <ul class="flex flex-wrap gap-2">
        {study.data.metrics.map((metric) => (
          <li class="rounded-md border border-cyan-900 bg-cyan-950/40 px-3 py-1 text-xs text-cyan-200">{metric}</li>
        ))}
      </ul>
    </header>
    <div class="space-y-4 [&_code]:rounded [&_code]:bg-slate-800 [&_code]:px-1 [&_code]:py-0.5 [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-semibold [&_h3]:mt-6 [&_h3]:text-lg [&_h3]:font-semibold [&_li]:ml-5 [&_li]:list-disc [&_p]:text-slate-300 [&_table]:w-full [&_table]:text-sm [&_td]:border [&_td]:border-slate-700 [&_td]:px-3 [&_td]:py-2 [&_th]:border [&_th]:border-slate-700 [&_th]:bg-slate-800 [&_th]:px-3 [&_th]:py-2">
      <Content />
    </div>
  </article>
</BaseLayout>

<script>
  import mermaid from 'mermaid';

  const initMermaid = async () => {
    const nodes = document.querySelectorAll('pre.mermaid');
    if (nodes.length === 0) return;

    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      securityLevel: 'loose',
      flowchart: { curve: 'basis' },
      themeVariables: {
        primaryColor: '#0e7490',
        primaryTextColor: '#e2e8f0',
        primaryBorderColor: '#22d3ee',
        lineColor: '#64748b',
        secondaryColor: '#1e293b',
        tertiaryColor: '#0f172a',
        fontFamily: 'ui-sans-serif, system-ui, sans-serif',
      },
    });

    await mermaid.run({ nodes: [...nodes] });
  };

  initMermaid();
  document.addEventListener('astro:page-load', initMermaid);
</script>
