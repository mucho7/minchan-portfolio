---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';

const caseStudies = (await getCollection('case-studies')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Case Studies | 김민찬 포트폴리오"
  description="Agent UI 공통화, 대용량 시계열 성능, 도구형 UI 흐름 설계 등 프론트엔드 프로젝트 Case Study"
>
  <section class="space-y-4">
    <h1 class="text-3xl font-bold">Case Studies</h1>
    <p class="max-w-3xl text-slate-300">
      어떤 문제를 맡았고, 어떤 기준으로 의사결정했으며, 그 결과 제품과 팀에 어떤 변화가 있었는지 정리했습니다.
    </p>
  </section>

  <section class="mt-10 space-y-4">
    {caseStudies.map((study) => (
      <CaseStudyCard study={study} variant="list" />
    ))}
  </section>
</BaseLayout>
