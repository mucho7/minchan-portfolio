---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const caseStudies = (await getCollection('case-studies')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Case Studies | 김민찬 포트폴리오"
  description="Agent UI 공통화, 대용량 시계열 성능, 도구형 UI 흐름 설계 등 프론트엔드 프로젝트 Case Study"
>
  <section class="space-y-4">
    <h1 class="text-3xl font-bold">Case Studies</h1>
    <p class="max-w-3xl text-slate-300">
      프로젝트별로 문제 정의부터 결과까지 같은 포맷으로 정리했습니다. 기술 선택의 이유와 트레이드오프를 확인할 수 있습니다.
    </p>
  </section>

  <section class="mt-10 space-y-4">
    {caseStudies.map((study) => (
      <a href={`${baseUrl}case-studies/${study.id}/`} class="block rounded-xl border border-slate-800 bg-slate-900 p-6 transition hover:border-cyan-400">
        <p class="text-xs text-slate-400">{study.data.period} · {study.data.role}</p>
        <h2 class="mt-1 text-xl font-semibold">{study.data.title}</h2>
        <p class="mt-2 text-slate-300">{study.data.summary}</p>
        <ul class="mt-3 flex flex-wrap gap-2">
          {study.data.skills.map((skill) => (
            <li class="rounded-md bg-slate-800 px-2 py-1 text-xs text-slate-200">{skill}</li>
          ))}
        </ul>
      </a>
    ))}
  </section>
</BaseLayout>
