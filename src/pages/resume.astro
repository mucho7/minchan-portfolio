---
import BaseLayout from '../layouts/BaseLayout.astro';

const resumePdfUrl = `${import.meta.env.BASE_URL}resume/resume.pdf`;

const resume = {
  name: 'FE Developer 이력서',
  oneLine: '복잡한 도메인을 사용자 경험으로 바꾸는 프론트엔드 개발 경력을 정리한 범용 이력서입니다.',
  highlights: [
    'Agent UI 공통화 및 재사용 구조 설계 (재사용률 ~60%)',
    '대용량 시계열 데이터 시각화 성능 개선 (5천만 건, LTTB)',
    'Monaco Editor 기반 웹 에디터 및 클라우드 콘솔 UI 개발'
  ]
};
---

<BaseLayout
  title="Resume | 김민찬 포트폴리오"
  description="김민찬 FE Developer 이력서 PDF 다운로드 및 경력 요약"
>
  <section class="space-y-4">
    <h1 class="text-3xl font-bold">Resume</h1>
    <p class="max-w-3xl text-slate-300">
      이력서 PDF와 함께 Case Study에서 프로젝트별 문제 해결 맥락을 더 자세히 확인할 수 있습니다.
    </p>
  </section>

  <section class="mt-10">
    <article class="rounded-xl border border-slate-800 bg-slate-900 p-6">
      <h2 class="text-xl font-semibold">{resume.name}</h2>
      <p class="mt-2 text-sm text-slate-300">{resume.oneLine}</p>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-slate-300">
        {resume.highlights.map((highlight) => (
          <li>{highlight}</li>
        ))}
      </ul>
      <div class="mt-6 flex flex-wrap gap-4">
        <a
          href={resumePdfUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-lg bg-cyan-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-cyan-500"
        >
          PDF 다운로드
        </a>
        <a href={`${import.meta.env.BASE_URL}case-studies/`} class="inline-block text-sm text-cyan-300 hover:text-cyan-200">
          Case Study 보기 →
        </a>
      </div>
    </article>
  </section>
</BaseLayout>
