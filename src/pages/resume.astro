---
import BaseLayout from '../layouts/BaseLayout.astro';

const resumes = [
  {
    name: '코드잇 지원 이력서',
    oneLine: '학습 경험과 도구형 UI 개선 경험을 중심으로 정리한 버전',
    highlights: ['Agent UI 공통화(재사용률 60%)', '대용량 시계열 데이터 성능 개선', 'Monaco 기반 웹 에디터 구현'],
    href: '#'
  },
  {
    name: '오늘의집 지원 이력서',
    oneLine: '사용자 행동 흐름과 콘텐츠 탐색 경험 연결을 강조한 버전',
    highlights: ['사용자 행동 기반 경험 설계', '반복 UI 패턴 공통화', '배포/운영 자동화 학습 적용'],
    href: '#'
  }
];
---

<BaseLayout title="Resume | 김민찬 포트폴리오">
  <section class="space-y-4">
    <h1 class="text-3xl font-bold">Resume</h1>
    <p class="max-w-3xl text-slate-300">
      지원 포지션에 맞춰 이력서 버전을 관리합니다. 원본 PDF는 민감 정보 검토 후 공유할 수 있도록 준비 중입니다.
    </p>
  </section>

  <section class="mt-10 grid gap-5 md:grid-cols-2">
    {resumes.map((resume) => (
      <article class="rounded-xl border border-slate-800 bg-slate-900 p-6">
        <h2 class="text-xl font-semibold">{resume.name}</h2>
        <p class="mt-2 text-sm text-slate-300">{resume.oneLine}</p>
        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-slate-300">
          {resume.highlights.map((highlight) => (
            <li>{highlight}</li>
          ))}
        </ul>
        <a href={resume.href} class="mt-6 inline-block text-sm text-cyan-300 hover:text-cyan-200">
          PDF 링크 (준비 중)
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
